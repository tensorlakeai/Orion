# Curated sqllogictest corpus for Orion's SQLite/libSQL query surface.
# This is intentionally small enough to run in local smoke tests. Larger
# imported SQLite/libSQL corpora should be added beside this file over time.

statement ok
PRAGMA foreign_keys = ON

statement ok
CREATE TABLE slt_parent (
  id INTEGER PRIMARY KEY,
  name TEXT NOT NULL UNIQUE,
  child_count INTEGER NOT NULL DEFAULT 0
)

statement ok
CREATE TABLE slt_child (
  id INTEGER PRIMARY KEY,
  parent_id INTEGER NOT NULL REFERENCES slt_parent(id),
  label TEXT NOT NULL,
  amount INTEGER NOT NULL CHECK (amount >= 0)
)

statement ok
CREATE INDEX slt_child_parent_amount_idx ON slt_child(parent_id, amount)

statement ok
CREATE VIEW slt_child_summary AS
  SELECT parent_id, count(*) AS children, sum(amount) AS total
  FROM slt_child
  GROUP BY parent_id

statement ok
CREATE TRIGGER slt_child_ai AFTER INSERT ON slt_child
BEGIN
  UPDATE slt_parent
  SET child_count = child_count + 1
  WHERE id = new.parent_id;
END

statement ok
INSERT INTO slt_parent(id, name) VALUES (1, 'acme'), (2, 'globex')

statement ok
BEGIN

statement ok
INSERT INTO slt_child(id, parent_id, label, amount) VALUES (10, 1, 'api', 5)

statement ok
SAVEPOINT adjust_amount

statement ok
UPDATE slt_child SET amount = 99 WHERE id = 10

statement ok
ROLLBACK TO adjust_amount

statement ok
RELEASE adjust_amount

statement ok
INSERT INTO slt_child(id, parent_id, label, amount) VALUES (11, 1, 'worker', 7)

statement ok
COMMIT

query TII nosort
WITH totals AS (
  SELECT parent_id, sum(amount) AS total
  FROM slt_child
  GROUP BY parent_id
)
SELECT p.name, p.child_count, totals.total
FROM slt_parent AS p
JOIN totals ON totals.parent_id = p.id
WHERE p.id = 1
----
acme
2
12

query II nosort
SELECT children, total FROM slt_child_summary WHERE parent_id = 1
----
2
12

